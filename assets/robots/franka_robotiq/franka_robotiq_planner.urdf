    <child link="robotiq_mount_link"/>
  </joint>

  <!--
    Semantic Robotiq base frame.
    This is intended to match the runtime USD prim
    /Robotiq_2F_85/base_link, so TCP offsets measured against that prim can
    be used directly here.
  -->
  <link name="robotiq_base_link"/>
  <joint name="robotiq_base_joint" type="fixed">
    <origin xyz="0 0 0" rpy="1.5707967468 0.0 2.3561944372"/>
    <parent link="robotiq_mount_link"/>
    <child link="robotiq_base_link"/>
  </joint>

  <link name="robotiq_base_geometry_link">
    <visual>
      <origin xyz="-0.002 -0.00546 -0.002" rpy="0 0 3.1415927"/>
      <geometry>
        <mesh filename="./meshes/Defeatured_2F_85_PAD_OPEN_basestep.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="-0.002 -0.00546 -0.002" rpy="0 0 3.1415927"/>
      <geometry>
        <mesh filename="./meshes/Defeatured_2F_85_PAD_OPEN_basestep.obj" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>
  <joint name="robotiq_base_geometry_joint" type="fixed">
    <origin xyz="-0.0028284 0 0.003" rpy="-1.5707964 0 2.3561945"/>
    <parent link="robotiq_base_link"/>
    <child link="robotiq_base_geometry_link"/>
  </joint>

  <link name="robotiq_tcp"/>
  <joint name="robotiq_tcp_joint" type="fixed">
    <!--
      Planner TCP for the fixed-tool Robotiq model.
      Position is set from the runtime midpoint of
      left_inner_finger_pad/right_inner_finger_pad expressed in runtime
      /Robotiq_2F_85/base_link.
      Orientation is chosen to match Panda grasp semantics and quaternion
      convention:
        - +Y: finger closing direction (right pad -> left pad)
        - +Z: grasp approach direction (base -> pad midpoint)
      The frame is additionally rolled 180 degrees about its local +Z so that
      the same target quaternion used for Panda (`[1, 0, 0, 0]`) corresponds
      to the same visual "from-below" grasp orientation on Robotiq.
    -->
    <origin xyz="-0.0007938554 0.1361235441 0.0" rpy="-1.5707963268 -1.5707963268 0.0"/>
    <parent link="robotiq_base_link"/>
    <child link="robotiq_tcp"/>
  </joint>
</robot>
